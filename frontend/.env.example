# Backend API URL — change to your machine's IP when running on network

# Use localhost for local-only development:
VITE_API_URL=http://localhost:5000

# Use your network IP to access from other devices:
# VITE_API_URL=http://192.168.1.15:5000

# Use for production:
# VITE_API_URL=https://shivamelectronic.onrender.com

# Sentry Error Tracking DSN (Client-side)
VITE_SENTRY_DSN=
